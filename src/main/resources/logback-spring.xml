<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <appender name="SYS_FILE" class="ch.qos.logback.core.FileAppender">
        <file>logs/SysLogs.txt</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="DB_FILE" class="ch.qos.logback.core.FileAppender">
        <file>logs/DatabaseLogs.txt</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level - %msg%n</pattern>
        </encoder>
    </appender>

    <logger name="syslogs" level="INFO" additivity="false">
        <appender-ref ref="SYS_FILE" />
    </logger>

    <logger name="databaselogs" level="DEBUG" additivity="false">
        <appender-ref ref="DB_FILE" />
    </logger>

    <root level="INFO">
        <appender-ref ref="SYS_FILE" />
    </root>

</configuration>